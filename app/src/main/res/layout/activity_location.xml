<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:map="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".locations.MapsActivity">



    <SearchView
        android:id="@+id/search_map"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="1dp"
        android:background="@drawable/map_round"
        android:elevation="10dp"
        android:iconifiedByDefault="false"
        android:paddingLeft="5dp"
        android:queryHint="Near Place city search..."



        />


    <fragment
        android:layout_below="@+id/search_map"
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="0dp"
        android:layout_alignParentBottom="true"
        android:layout_alignParentLeft="true"
        android:layout_alignParentStart="true"
        tools:context="pramod.consultency.com.users.locations.MapsActivity" />





</RelativeLayout>